# SportPlanner Environment Configuration

# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sportplanner
CONNECTION_STRING=Host=localhost;Database=sportplanner;Username=username;Password=password

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_ISSUER=SportPlanner
JWT_AUDIENCE=SportPlanner.Users
JWT_EXPIRY_MINUTES=60

# API Configuration
API_BASE_URL=https://localhost:7072
FRONTEND_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:4200,https://localhost:4200

# Environment
ASPNETCORE_ENVIRONMENT=Development
NODE_ENV=development

# Logging
LOG_LEVEL=Information
SERILOG_MINIMUM_LEVEL=Debug

# File Storage (if needed)
FILE_STORAGE_PATH=./uploads
MAX_FILE_SIZE_MB=10

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@sportplanner.com

# Redis (for caching, if implemented)
REDIS_CONNECTION_STRING=localhost:6379

# Application Settings
APP_NAME=SportPlanner
APP_VERSION=1.0.0
DEFAULT_LANGUAGE=es
TIMEZONE=Europe/Madrid