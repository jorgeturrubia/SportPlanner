{
  "mcpServers": {
    "pm-agent-context": {
      "command": "node",
      "args": ["-e", "console.log('PM Agent Context Provider - Ready for autonomous development!')"],
      "env": {
        "PM_AGENT_ACTIVE": "true"
      }
    }
  },
  "permissions": {
    "allow": [
      "Task(*)",
      "Read(**/*.md)",
      "Read(**/*.json)",
      "Read(**/*.ts)",
      "Read(**/*.cs)",
      "Read(**/*.html)",
      "Write(src/**/*)",
      "Edit(src/**/*)",
      "MultiEdit(src/**/*)",
      "Bash(dotnet *)",
      "Bash(npm *)",
      "Bash(ng *)",
      "Grep(*)",
      "Glob(*)",
      "LS(*)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/appsettings.*.json)",
      "Write(.env*)",
      "Write(**/appsettings.*.json)",
      "Bash(rm -rf *)",
      "Bash(del /f /q *)",
      "Bash(format *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command", 
            "command": "echo '🚀 PM Agent System Active - Autonomous development ready!' && echo 'Context: Full-stack development with intelligent agent coordination' && echo 'Available: Project Manager + Specialized Tech Agents'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "echo '🤖 Agent task completed - validating inter-agent consistency...'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "echo '📝 PM Agent system: Preparing to modify files with coordination protocols active'"
          }
        ]
      }
    ]
  },
  "env": {
    "PM_AGENT_SYSTEM": "active",
    "AUTONOMOUS_DEVELOPMENT": "enabled",
    "AGENT_DISCOVERY": "auto",
    "CONTEXT_ANALYSIS": "deep",
    "COORDINATION_MODE": "intelligent"
  }
}