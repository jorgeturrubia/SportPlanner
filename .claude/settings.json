{
  "permissions": {
    "allow": [
      "Write(Steering/**/*.md)",
      "Read(Steering/**/*.md)",
      "Edit(Steering/**/*.md)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(ls *)",
      "LS(**/*)",
      "Glob(**/*.md)",
      "Glob(**/*.json)",
      "Glob(**/*.ts)",
      "Glob(**/*.cs)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 Hooks/steering-sync.py",
            "timeout": 10
          },
          {
            "type": "command", 
            "command": "python3 Hooks/steering-format.py",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "env": {
    "PYTHONPATH": ".",
    "CLAUDE_PROJECT_DIR": "."
  }
}
